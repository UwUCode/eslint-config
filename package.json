{
  "name": "@uwu-codes/eslint-config",
  "version": "2.0.1",
  "description": "My eslint config for my projects.",
  "packageManager": "bun@1.3.10",
  "module": "dist/eslint.config.mjs",
  "exports": {
    ".": {
      "import": "./dist/eslint.config.mjs"
    }
  },
  "scripts": {
    "prepare": "bun run build",
    "build": "bun build eslint.config.mts --target=node --format=esm --outfile=dist/eslint.config.mjs --packages external && tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UwUCode/eslint-config.git"
  },
  "author": "Donovan_DMC",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/UwUCode/eslint-config/issues"
  },
  "homepage": "https://github.com/UwUCode/eslint-config#readme",
  "engines": {
    "bun": ">=1.3",
    "node": ">=22"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^59.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript-eslint": "^8.57.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "jiti": "^2.6.1",
    "typescript": "^5.9.3"
  }
}
